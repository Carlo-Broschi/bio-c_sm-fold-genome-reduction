    given-names: Minoru
    email: vivaldi.rv484@gmail.com
license: CC-BY-4.0
repository-code: "https://github.com/Carlo-Broschi/bio-c_sm-fold-genome-reduction"
keywords:
  - phylogenetics
  - Sm/Lsm
  - Hfq
  - genome reduction
  - DPANN
  - Asgard archaea
  - CPR / Patescibacteria
  - endosymbiont
  - molecular evolution
